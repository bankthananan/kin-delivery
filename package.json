{
  "name": "kin-delivery",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "pnpm --filter @kin-delivery/database prisma migrate dev",
    "db:seed": "pnpm --filter @kin-delivery/database prisma db seed",
    "db:studio": "pnpm --filter @kin-delivery/database prisma studio",
    "db:reset": "pnpm --filter @kin-delivery/database prisma migrate reset",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}
