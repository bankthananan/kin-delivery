# Database
DATABASE_URL=postgresql://kin:kin_dev_password@localhost:5432/kin_delivery

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Omise (Payment)
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxx
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxx

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxx

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=kin-delivery
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@kin-delivery.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# App Config
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Customer App
EXPO_PUBLIC_API_URL=http://localhost:3000

# Web Apps
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
